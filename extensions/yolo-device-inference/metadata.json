{
  "id": "yolo-device-inference",
  "name": "yolo device inference",
  "version": "1.0.0",
  "description": "YOLOv8 device inference extension with automatic detection on data source updates",
  "author": "NeoMind Team",
  "license": "Apache-2.0",
  "type": "native",
  "categories": [
    "ai",
    "vision",
    "detection"
  ],
  "homepage": "https://github.com/camthink-ai/NeoMind-Extensions/tree/main/extensions/yolo-device-inference",
  "builds": {
    "darwin-aarch64": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/v2.3.0/yolo-device-inference-2.3.0-darwin_aarch64.nep"
    },
    "darwin-x86_64": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/v2.3.0/yolo-device-inference-2.3.0-darwin_x86_64.nep"
    },
    "linux-x86_64": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/v2.3.0/yolo-device-inference-2.3.0-linux_amd64.nep"
    },
    "linux-aarch64": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/v2.3.0/yolo-device-inference-2.3.0-linux_arm64.nep"
    },
    "windows-x86_64": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/v2.3.0/yolo-device-inference-2.3.0-windows_x86_64.nep"
    }
  },
  "frontend": {
    "components": [
      {
        "name": "DeviceInferenceCard",
        "type": "widget",
        "displayName": "YOLO Device Inference",
        "description": "Bind device with image data source for automatic YOLO object detection",
        "icon": "camera",
        "defaultSize": {
          "width": 400,
          "height": 350
        },
        "minSize": {
          "width": 300,
          "height": 250
        },
        "maxSize": {
          "width": 600,
          "height": 500
        },
        "configSchema": {
          "confidence": {
            "type": "number",
            "required": false,
            "default": 0.25,
            "description": "Confidence threshold for detections (0.0-1.0)"
          },
          "drawBoxes": {
            "type": "boolean",
            "required": false,
            "default": true,
            "description": "Draw detection boxes on images"
          },
          "showPreview": {
            "type": "boolean",
            "required": false,
            "default": true,
            "description": "Show detection preview image"
          }
        },
        "refreshable": false,
        "refreshInterval": 0
      }
    ],
    "entrypoint": "yolo-device-inference-components.umd.cjs"
  }
}
