{
  "id": "ocr-device-inference",
  "version": "1.0.0",
  "entrypoint": "ocr-device-inference-components.umd.cjs",
  "components": [
    {
      "name": "OcrDeviceCard",
      "type": "widget",
      "displayName": "OCR",
      "description": "Upload images for OCR text recognition or manage device bindings",
      "icon": "file-text",
      "defaultSize": { "width": 450, "height": 500 },
      "minSize": { "width": 350, "height": 400 },
      "maxSize": { "width": 600, "height": 800 },
      "configSchema": {
        "drawBoxes": {
          "type": "boolean",
          "default": true,
          "description": "Draw text bounding boxes on images"
        },
        "showPreview": {
          "type": "boolean",
          "default": true,
          "description": "Show recognition results preview"
        }
      }
    }
  ],
  "i18n": {
    "defaultLanguage": "zh",
    "supportedLanguages": ["zh", "en"]
  },
  "dependencies": {
    "react": ">=18.0.0"
  }
}
